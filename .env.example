# GODMODE Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to source control.

# ── Slack (optional) ───────────────────────────────────────────────────────────
# Leave ALL Slack vars unset to enable Slack-optional mode: Argus will generate a
# local report.html (all findings + inline screenshots) and open it in the browser.
#
# Bot User OAuth Token from your Slack App (must start with xoxb-)
# Get from: api.slack.com/apps → Your App → OAuth & Permissions → Bot User OAuth Token
# SLACK_BOT_TOKEN=xoxb-your-token-here

# Slack signing secret — used to verify slash command / interaction payloads
# Get from: api.slack.com/apps → Your App → Basic Information → Signing Secret
# SLACK_SIGNING_SECRET=your-signing-secret-here

# Channel IDs (not names) — right-click channel in Slack → Copy link → last segment is the ID
# SLACK_CHANNEL_CRITICAL=C0000000000
# SLACK_CHANNEL_WARNINGS=C0000000001
# SLACK_CHANNEL_DIGEST=C0000000002

# ── Target URLs ────────────────────────────────────────────────────────────────
# Base URL of your local dev environment
TARGET_DEV_URL=http://localhost:3000
# Base URL of staging. Leave blank or remove to enable CSS-only analysis mode.
TARGET_STAGING_URL=https://staging.yourapp.com

# ── Comparison Thresholds ──────────────────────────────────────────────────────
# Pixel diff percentage above which a screenshot difference is flagged (0–100)
SCREENSHOT_DIFF_THRESHOLD=0.5

# ── A12: Deep Accessibility (optional) ─────────────────────────────────────────
# WCAG AA minimum contrast ratio for color blind simulation checks (default: 4.5)
# A11Y_CONTRAST_AA=4.5
# Maximum axe-core violations to report per page run (default: 50)
# A11Y_MAX_AXE=50

# ── GitHub PR rich comments + Check Runs (optional) ───────────────────────────
# New criticals threshold before blocking PR merge (default: 1; set 0 to never block)
# ARGUS_CRITICAL_THRESHOLD=1
# URL of visual diff image to embed in PR comment (set after uploading CI artifact)
# ARGUS_DIFF_IMAGE_URL=
# GitHub Check Run name (default: argus-qa)
# GITHUB_CHECK_NAME=argus-qa

# ── PR Validator (optional) ─────────────────────────────────────────
# Severity that blocks PR merge when using argus_pr_validate: none | warning | critical
# ARGUS_BLOCK_ON=critical

# ── A9: Motion & Animation (optional) ──────────────────────────────────────────
# Interactive animated element count threshold — flag when count ≥ N (default: 1)
# MOTION_ANIM_COUNT=1

# ── A10: Font Loading (optional) ───────────────────────────────────────────────
# Slow web font load threshold in milliseconds (default: 1000)
# FONT_SLOW_MS=1000

# ── Output ─────────────────────────────────────────────────────────────────────
REPORT_OUTPUT_DIR=./reports

# ── Performance ────────────────────────────────────────────────────────────────
# Number of parallel MCP clients for route crawling. Default 1 = sequential.
# Increase to cut wall-clock on large apps (e.g., ARGUS_CONCURRENCY=4).
# ARGUS_CONCURRENCY=1

# ── Server (for slash command + interaction handlers) ──────────────────────────
PORT=3001

# ── OpenTelemetry (optional) ───────────────────────────────────────────────────
# Ship spans + metrics to any OTLP collector (Jaeger, Grafana Tempo, Honeycomb, etc.)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Set to 1 to print spans to stdout for local dev (no collector needed)
# ARGUS_OTEL_CONSOLE=1

# ── Logging (optional) ─────────────────────────────────────────────────────────
# Log level: info (default), debug, warn, error
# ARGUS_LOG_LEVEL=info
# Output format: 1 = force pino-pretty, 0 = force JSON, unset = auto-detect TTY
# ARGUS_LOG_PRETTY=1

# ── Retry (optional) ───────────────────────────────────────────────────────────
# Max retries on navigate/fill in CdpBrowserAdapter (default: 3). Set to 1 in CI.
# ARGUS_RETRY_ATTEMPTS=3

# ── Watch mode (optional) ──────────────────────────────────────────────────────
# Poll interval for `npm run watch` in ms (default: 1000)
# ARGUS_WATCH_INTERVAL_MS=1000
# Port for the live watch-mode web dashboard (default: 3002)
# ARGUS_WATCH_UI_PORT=3002

# ── D9: Figma design fidelity (optional) ───────────────────────────────────────
# Personal Access Token from figma.com/settings — enables argus_design_audit and
# the design-fidelity analyzer. Omit to skip design fidelity audits.
# FIGMA_API_TOKEN=figd_...

# ── A8: Visual regression thresholds (optional) ────────────────────────────────
# % of pixels changed vs baseline → warning (default: 0.1) / critical (default: 5.0)
# VISUAL_WARN_PERCENT=0.1
# VISUAL_CRIT_PERCENT=5.0

# ── MCP client (optional) ──────────────────────────────────────────────────────
# Chrome remote-debug URL the headless MCP client connects to (default: http://127.0.0.1:9222)
# MCP_BROWSER_URL=http://127.0.0.1:9222
# Per-tool-call timeout in ms for the headless JSON-RPC client (default: 30000)
# MCP_TOOL_TIMEOUT_MS=30000

# ── Chrome launcher / doctor (optional) ────────────────────────────────────────
# Explicit Chrome binary path — overrides cross-platform auto-detection
# ARGUS_CHROME_PATH=
# CDP port checked by `npm run doctor` and opened by `npm run chrome` (default: 9222)
# ARGUS_CHROME_PORT=9222

# ── Auth flow credentials (optional — referenced from targets.js auth steps) ───
# ARGUS_AUTH_EMAIL=qa@example.com
# ARGUS_AUTH_PASSWORD=

# ── Timeouts (optional) ────────────────────────────────────────────────────────
# Slack slash-command crawl timeout in ms (default: 120000)
# ARGUS_CRAWL_TIMEOUT_MS=120000
# Lighthouse audit timeout in ms (default: 120000)
# ARGUS_LIGHTHOUSE_TIMEOUT=120000

# ── Intelligent baseline filtering + root cause linking (optional) ────────────
# Cross-run noise classifier — downgrades flip-flopping findings to info (default: on)
# ARGUS_NOISE_FILTER=0
# Annotate new findings with recent git commits mapped to their route (default: on)
# ARGUS_ROOT_CAUSE=0

# ── C1: Codebase analysis (optional) ──────────────────────────────────────────
# Path to your app's source directory for env var audit + dead route detection
# ARGUS_SOURCE_DIR=../my-app/src
# Path to your app's .env file for env var cross-reference
# ARGUS_ENV_FILE=../my-app/.env

# ── C2: GitHub PR integration (optional) ───────────────────────────────────────
# Personal Access Token or workflow GITHUB_TOKEN
# GITHUB_TOKEN=ghp_...
# Repository in owner/repo format (e.g., acme/my-app)
# GITHUB_REPOSITORY=
# PR number — typically injected by CI: ${{ github.event.pull_request.number }}
# GITHUB_PR_NUMBER=
# Full URL to the hosted HTML report — linked from the commit status check
# ARGUS_REPORT_URL=
